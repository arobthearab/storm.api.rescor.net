# =============================================================================
# STORM API Environment Configuration
# =============================================================================
# Only project-specific values here.  Infisical bootstrap credentials
# (HOST, CLIENT_ID, CLIENT_SECRET) cascade from core.rescor.net/.env.
#
# To use: copy to .env and set your project ID.
# See docs/CONFIGURATION.md for the full reference.
# =============================================================================

# This project's Infisical project ID
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev

# -----------------------------------------------------------------------------
# Phase Override (optional)
# -----------------------------------------------------------------------------
# Controls PhaseManager behavior (authentication enforcement, etc.)
# Values: development | uat | production
# Default when omitted: development (auth bypassed, synthetic admin user)
# See docs/AUTHENTICATION.md for phase-specific auth behavior.
#
# PHASE=development
