# =============================================================================
# STORM API Environment Configuration
# =============================================================================
# This file contains ONLY the bootstrap credentials needed to connect to
# Infisical (the secrets store).  ALL runtime configuration (Neo4j URIs,
# Keycloak/IDP settings, etc.) is loaded from Infisical at startup via
# @rescor/core-config — see docs/CONFIGURATION.md for the full reference.
#
# To use: copy to .env and fill in Infisical credentials.
# Requires Node >= 20.12.0 (native --env-file support).
# =============================================================================

# -----------------------------------------------------------------------------
# Infisical Connection (Secret Store Bootstrap)
# -----------------------------------------------------------------------------
INFISICAL_HOST=http://localhost:3000
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=

# Infisical Project IDs
INFISICAL_CORE_PROJECT_ID=31ce7b6b-24ac-441f-ae3e-d47a13719238
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev

# -----------------------------------------------------------------------------
# Phase Override (optional)
# -----------------------------------------------------------------------------
# Controls PhaseManager behavior (authentication enforcement, etc.)
# Values: development | uat | production
# Default when omitted: development (auth bypassed, synthetic admin user)
# See docs/AUTHENTICATION.md for phase-specific auth behavior.
#
# PHASE=development
